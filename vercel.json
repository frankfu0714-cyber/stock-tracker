{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "manifest.webmanifest", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/price", "dest": "/api/price.js" },
    { "src": "/api/fx", "dest": "/api/fx.js" },
    { "src": "/api/ocr", "dest": "/api/ocr.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
